# Copy to .env for local development (never commit .env).

# --- Core ---
# Bind (optional; uvicorn defaults are fine for local dev)
# HOST=0.0.0.0
# PORT=8000

# Shared secret for HMAC auth between add-on and backend (Phase 4)
# HMAC_SECRET=change-me-use-long-random-bytes
# Optional: during rotation, old secret so clients still on the prior key verify (requires HMAC_SECRET set).
# HMAC_SECRET_PREVIOUS=

# Deploy profile: set to production on Render so POST /v1/score cannot run without HMAC_SECRET (503).
# Omit or use development locally so HMAC is optional when HMAC_SECRET is unset.
# ENVIRONMENT=production

# --- Replay protection (schema 1.1+; production requires issued_at + request_id in JSON body) ---
# Max |now - issued_at| in seconds (default 120).
# SCORE_MAX_SKEW_SECONDS=120
# How long the same request_id is remembered in-process (default 300). Single-instance only.
# REPLAY_REQUEST_ID_TTL_SECONDS=300
# Upper bound on remembered request_ids under abuse (default 50000).
# REPLAY_REQUEST_ID_MAX_ENTRIES=50000

# --- External reputation (Phase 3) ---
# Use these EXACT variable names (read by `app/reputation/providers.py` via os.getenv).
#
# Local: copy this file to `backend/.env` (same folder as `pyproject.toml`), uncomment and fill.
# The app loads `backend/.env` on startup (python-dotenv); restart uvicorn after edits.
# Keys already set in your shell or in Render take precedence over `.env`.
#
# Render: Dashboard → your Web Service → Environment → add each variable → Save → redeploy/restart.
#
# Google Cloud Console → APIs & Services → Library → enable "Safe Browsing API" → Credentials → API key
# GOOGLE_SAFE_BROWSING_API_KEY=
#
# https://www.virustotal.com → profile / API key
# VIRUSTOTAL_API_KEY=

# --- Logging ---
# LOG_LEVEL=info
# DEBUG_LOGGING=false
